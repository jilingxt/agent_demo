{
  "version": "1",
  "scope_note": "本表登记可复用的事实关系组件，不是案件类型白名单。组件只评价可由证据支持或反对的事实关系；罪名、违法成立、处罚选择及法条适用仍由确定性规则和人工法律审查完成。未匹配组件的事实继续进入主观证据评估，并由贝叶斯工具显式安全弃权。",
  "source_laws": [
    "中华人民共和国刑法（2023年修正）",
    "中华人民共和国治安管理处罚法（2025年修订）",
    "中华人民共和国刑事诉讼法（2018年修正）"
  ],
  "universal_factual_elements": [
    "actor_identity",
    "conduct",
    "target_or_object",
    "time_and_place",
    "result_or_risk",
    "causation_or_connection",
    "alternative_explanation"
  ],
  "deterministic_legal_elements": [
    "age_threshold",
    "amount_threshold",
    "frequency_threshold",
    "legal_defense",
    "legal_status",
    "legal_duty",
    "authorization_validity",
    "administrative_criminal_boundary",
    "jurisdiction",
    "limitation_period",
    "legal_applicability",
    "punishment"
  ],
  "case_families": [
    {
      "family_id": "conduct_result",
