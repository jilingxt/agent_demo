      "input_map": {
        "public_order_conduct": "conduct",
        "public_context": "public_context",
        "operational_impact": "operational_impact",
        "persistence_or_group": "persistence_or_group"
      },
      "derived_nodes": ["order_disruption"],
      "priority": 0
    },
    {
      "model_id": "public_safety",
      "path": "public_safety_v1.json",
      "domains": ["public_safety"],
      "trigger_predicates": [
        "hazardous_conduct",
        "dangerous_object_or_condition",
        "exposure",
